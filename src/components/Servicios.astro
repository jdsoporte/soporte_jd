---
const servicios = [
  {
    icon: "🌐",
    titulo: "Redes y Datos",
    descripcion: "Instalación, configuración y mantenimiento de redes cableadas e inalámbricas (WiFi). Optimización de velocidad, cobertura y seguridad para tu hogar o empresa en Montería.",
    tags: ["REDES", "WIFI", "CABLEADO", "MONTERÍA"],
    schema: "NetworkInstallation"
  },
  {
    icon: "📷",
    titulo: "Cámaras CCTV",
    descripcion: "Diseño e instalación de sistemas de videovigilancia. Monitoreo remoto desde tu celular, cámaras HD para interiores y exteriores. Protege tu negocio o hogar en Córdoba.",
    tags: ["VIGILANCIA", "HD", "REMOTO", "CCTV"],
    schema: "SecuritySystem"
  },
  {
    icon: "🖥️",
    titulo: "Soporte y Reparación de Equipos",
    descripcion: "Diagnóstico y reparación de computadores, laptops y periféricos en Montería. Instalación de software, formateo, limpieza y mantenimiento preventivo. Visitamos tu domicilio.",
    tags: ["PC", "LAPTOP", "DOMICILIO", "FORMATEO"],
    schema: "ComputerRepair"
  },
  {
    icon: "📱",
    titulo: "Menú Digital para Negocios",
    descripcion: "Automatiza tu restaurante, tienda o negocio en Montería con menús digitales: toma de pedidos, registro de inventario, historial de ventas y mucho más. Ideal para pymes.",
    tags: ["PEDIDOS", "INVENTARIO", "DIGITAL", "PYMES"],
    schema: "SoftwareApplication"
  }
];
---

<section id="servicios" aria-labelledby="servicios-titulo">
  <span class="section-label">Lo que hacemos</span>
  <h2 class="section-title" id="servicios-titulo">
    Nuestros Servicios en<br /><em>Montería, Córdoba</em>
  </h2>
  <p class="section-desc">
    Soluciones tecnológicas completas para hogares y negocios. Atención directa, sin intermediarios, donde tú estés.
  </p>

  <div class="servicios-grid">
    {servicios.map((s, i) => (
      <article class="servicio-card" itemscope itemtype={`https://schema.org/${s.schema}`}>
        <div class="servicio-num" aria-hidden="true">0{i + 1}</div>
        <div class="servicio-icon" aria-hidden="true">{s.icon}</div>
        <h3 itemprop="name">{s.titulo}</h3>
        <p itemprop="description">{s.descripcion}</p>
        <div class="servicio-tags" aria-label="Etiquetas del servicio">
          {s.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <a
          href="#contacto"
          class="servicio-cta"
          aria-label={`Cotizar ${s.titulo}`}
        >
          Cotizar este servicio →
        </a>
      </article>
    ))}
  </div>
</section>

<style>
section {
  background: #0d1117;
}
h2 em { color: #f5a623; font-style: normal; }

.servicios-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px; margin-top: 52px;
}

.servicio-card {
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 18px; padding: 36px 28px;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; gap: 0;
  transition: transform .3s, border-color .3s, box-shadow .3s;
}
.servicio-card::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(35,85,180,.08) 0%, transparent 60%);
  opacity: 0; transition: opacity .3s;
}
.servicio-card:hover {
  transform: translateY(-6px);
  border-color: rgba(58,123,213,.4);
  box-shadow: 0 12px 40px rgba(35,85,180,.18);
}
.servicio-card:hover::before { opacity: 1; }

.servicio-num {
  position: absolute; top: 20px; right: 24px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 3.5rem; font-weight: 900;
  color: rgba(255,255,255,.04); line-height: 1;
  pointer-events: none; user-select: none;
}
.servicio-icon {
  width: 58px; height: 58px; border-radius: 14px;
  background: linear-gradient(135deg, #2355b4, #1a2a6c);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.7rem; margin-bottom: 20px;
  box-shadow: 0 4px 16px rgba(35,85,180,.35);
}
.servicio-card h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.35rem; font-weight: 700; margin-bottom: 10px; letter-spacing: .02em;
}
.servicio-card p {
  font-size: .92rem; color: rgba(255,255,255,.55); line-height: 1.65; flex: 1;
}
.servicio-tags {
  display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px;
}
.tag {
  background: rgba(245,166,35,.1); color: #f5a623;
  font-size: .7rem; font-weight: 700; letter-spacing: .1em;
  padding: 4px 10px; border-radius: 100px;
}
.servicio-cta {
  display: inline-block; margin-top: 20px;
  color: rgba(255,255,255,.4); font-size: .85rem; font-weight: 600;
  text-decoration: none; letter-spacing: .03em;
  transition: color .2s;
}
.servicio-cta:hover { color: #f5a623; }
</style>
