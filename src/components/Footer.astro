<footer role="contentinfo">
  <div class="footer-main">
    <div class="footer-brand">
      <img src="/logo.jpg" alt="Logo Soporte JD" width="48" height="48" loading="lazy" />
      <div>
        <div class="brand-name">SOPORTE <em>JD</em></div>
        <div class="brand-slogan">Protege Tu Espacio, Conecta Tu Futuro</div>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Navegación del pie de página">
      <strong>Servicios</strong>
      <a href="#servicios">Redes y Datos</a>
      <a href="#servicios">Cámaras CCTV</a>
      <a href="#servicios">Soporte Técnico</a>
      <a href="#menu-digital">Menú Digital</a>
    </nav>

    <div class="footer-contact">
      <strong>Contacto</strong>
      <a href="https://wa.me/573016537553" target="_blank" rel="noopener">💬 +57 301 653 7553</a>
      <a href="tel:+573016537553">📞 +57 301 653 7553</a>
      <a href="mailto:jdsoporte98@gmail.com">✉️ jdsoporte98@gmail.com</a>
      <span>📍 Montería, Córdoba, Colombia</span>
    </div>

    <div class="footer-seo">
      <strong>Zona de Servicio</strong>
      <p>Atendemos en <strong>Montería</strong> y toda la región de <strong>Córdoba</strong>, Colombia. Servicio a domicilio sin recargo.</p>
      <p style="margin-top:10px; font-size:.78rem;">Redes · CCTV · Soporte · Menú Digital</p>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} Soporte JD · Montería, Córdoba, Colombia</p>
    <p>Todos los derechos reservados</p>
  </div>
</footer>

<style>
footer {
  background: #080c12;
  border-top: 1px solid rgba(255,255,255,.06);
}
.footer-main {
  padding: 56px 6% 40px;
  display: grid; grid-template-columns: 2fr 1fr 1.5fr 1.5fr;
  gap: 40px;
}
@media(max-width: 900px) { .footer-main { grid-template-columns: 1fr 1fr; } }
@media(max-width: 560px) { .footer-main { grid-template-columns: 1fr; } }

.footer-brand { display: flex; align-items: flex-start; gap: 14px; }
.footer-brand img { border-radius: 8px; object-fit: cover; }
.brand-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.3rem; font-weight: 800; color: #fff;
}
.brand-name em { color: #f5a623; font-style: normal; }
.brand-slogan { font-size: .8rem; color: rgba(255,255,255,.35); margin-top: 4px; line-height: 1.4; }

.footer-nav, .footer-contact, .footer-seo {
  display: flex; flex-direction: column; gap: 10px;
}
.footer-nav strong, .footer-contact strong, .footer-seo strong {
  font-size: .78rem; letter-spacing: .12em; color: rgba(255,255,255,.3);
  text-transform: uppercase; margin-bottom: 4px;
}
.footer-nav a, .footer-contact a {
  font-size: .88rem; color: rgba(255,255,255,.55); text-decoration: none;
  transition: color .2s;
}
.footer-nav a:hover, .footer-contact a:hover { color: #f5a623; }
.footer-contact span { font-size: .88rem; color: rgba(255,255,255,.45); }
.footer-seo p { font-size: .85rem; color: rgba(255,255,255,.4); line-height: 1.6; }
.footer-seo strong { color: rgba(255,255,255,.6); font-size: inherit; letter-spacing: 0; text-transform: none; }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.05);
  padding: 20px 6%; display: flex; flex-wrap: wrap;
  justify-content: space-between; gap: 10px;
}
.footer-bottom p { font-size: .78rem; color: rgba(255,255,255,.25); }
</style>
