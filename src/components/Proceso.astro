---
const pasos = [
  { num: "01", titulo: "Contáctanos", desc: "Escríbenos por WhatsApp o llena el formulario. Cuéntanos qué necesitas." },
  { num: "02", titulo: "Diagnóstico", desc: "Analizamos tu caso y te enviamos una cotización clara y sin letra pequeña." },
  { num: "03", titulo: "Instalación", desc: "Vamos a donde estés en Montería. Instalamos, configuramos y probamos todo." },
  { num: "04", titulo: "Soporte", desc: "Te acompañamos después de la instalación. Siempre disponibles para ayudarte." },
];

const razones = [
  { icon: "🏠", titulo: "Servicio a Domicilio", desc: "No necesitas desplazarte. Llegamos donde estés en Montería y la región de Córdoba." },
  { icon: "💰", titulo: "Precios Justos", desc: "Cotizaciones claras y precios adaptados a pequeños y medianos negocios." },
  { icon: "🤝", titulo: "Atención Personalizada", desc: "Tratas directamente con el técnico. Sin intermediarios, sin demoras, sin excusas." },
  { icon: "🔒", titulo: "Trabajo Garantizado", desc: "Respaldamos nuestro trabajo. Si algo falla, regresamos sin costo adicional." },
];
---

<!-- PROCESO -->
<section id="proceso" aria-labelledby="proceso-titulo">
  <span class="section-label">Simple y rápido</span>
  <h2 class="section-title" id="proceso-titulo">¿Cómo Funciona?</h2>
  <p class="section-desc">En pocos pasos tienes tu solución tecnológica instalada y funcionando en Montería.</p>

  <ol class="pasos" role="list">
    {pasos.map((p, i) => (
      <li class="paso">
        <div class="paso-num" aria-label={`Paso ${p.num}`}>{p.num}</div>
        <h3>{p.titulo}</h3>
        <p>{p.desc}</p>
      </li>
    ))}
  </ol>
</section>

<!-- POR QUÉ ELEGIRNOS -->
<section id="porque" aria-labelledby="porque-titulo">
  <span class="section-label">Nuestro valor diferencial</span>
  <h2 class="section-title" id="porque-titulo">¿Por Qué Elegir<br /><em>Soporte JD?</em></h2>

  <div class="porque-grid">
    {razones.map(r => (
      <div class="porque-item">
        <div class="porque-icon" aria-hidden="true">{r.icon}</div>
        <h3>{r.titulo}</h3>
        <p>{r.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
/* PROCESO */
#proceso { background: #0d1117; }

.pasos {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0; margin-top: 52px; list-style: none;
  position: relative;
  counter-reset: none;
}
.pasos::before {
  content: ''; position: absolute; top: 36px; left: 8%; right: 8%; height: 2px;
  background: linear-gradient(90deg, #1a2a6c, #3a7bd5, #f5a623);
  z-index: 0;
}
@media(max-width: 640px) { .pasos::before { display: none; } .pasos { gap: 32px; } }

.paso {
  text-align: center; padding: 0 20px;
  position: relative; z-index: 1;
}
.paso-num {
  width: 72px; height: 72px; border-radius: 50%;
  background: linear-gradient(135deg, #2355b4, #1a2a6c);
  border: 3px solid #3a7bd5;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.8rem; font-weight: 900; color: #fff;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
  transition: transform .3s, box-shadow .3s;
}
.paso:hover .paso-num { transform: scale(1.1); box-shadow: 0 0 28px rgba(58,123,213,.5); }
.paso h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.15rem; font-weight: 700; margin-bottom: 8px;
}
.paso p { font-size: .88rem; color: rgba(255,255,255,.5); line-height: 1.6; }

/* POR QUÉ */
#porque {
  background: linear-gradient(180deg, #0d1117 0%, #0a1628 100%);
}
#porque h2 em { color: #f5a623; font-style: normal; }

.porque-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px; margin-top: 48px;
}
.porque-item {
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 14px; padding: 30px 24px;
  transition: border-color .3s, transform .3s, box-shadow .3s;
}
.porque-item:hover {
  border-color: #f5a623;
  transform: translateY(-5px);
  box-shadow: 0 8px 32px rgba(245,166,35,.1);
}
.porque-icon { font-size: 2.2rem; margin-bottom: 14px; }
.porque-item h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.15rem; font-weight: 700; margin-bottom: 8px;
}
.porque-item p { font-size: .88rem; color: rgba(255,255,255,.5); line-height: 1.6; }
</style>
