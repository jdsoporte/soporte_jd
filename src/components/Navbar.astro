---
---
<nav id="navbar">
  <a href="#inicio" class="nav-logo" aria-label="Soporte JD - Inicio">
    <img src="/logo.jpg" alt="Logo Soporte JD" width="48" height="48" />
    <span>SOPORTE <em>JD</em></span>
  </a>

  <ul class="nav-links" role="navigation" aria-label="Menú principal">
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#menu-digital">Menú Digital</a></li>
    <li><a href="#proceso">¿Cómo funciona?</a></li>
    <li><a href="#contacto">Contacto</a></li>
  </ul>

  <a
    href="https://wa.me/573016537553?text=Hola%2C%20vi%20su%20p%C3%A1gina%20y%20quiero%20una%20cotizaci%C3%B3n"
    class="nav-cta"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Cotizar por WhatsApp"
  >
    📲 Cotizar Ahora
  </a>

  <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 6%;
  background: rgba(13,17,23,0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,.06);
  transition: background .3s, padding .3s;
}
nav.scrolled {
  background: rgba(13,17,23,0.98);
  padding: 10px 6%;
}
.nav-logo {
  display: flex; align-items: center; gap: 12px; text-decoration: none;
}
.nav-logo img {
  height: 46px; width: 46px; border-radius: 8px; object-fit: cover;
}
.nav-logo span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.4rem; font-weight: 800; color: #fff; letter-spacing: .04em;
}
.nav-logo span em { color: #f5a623; font-style: normal; }

.nav-links {
  display: flex; gap: 32px; list-style: none;
}
.nav-links a {
  font-size: .9rem; font-weight: 500;
  color: rgba(255,255,255,.75); text-decoration: none;
  letter-spacing: .03em; transition: color .2s;
  position: relative; padding-bottom: 4px;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 0; height: 2px; background: #f5a623;
  transition: width .25s;
}
.nav-links a:hover { color: #f5a623; }
.nav-links a:hover::after { width: 100%; }

.nav-cta {
  background: #f5a623; color: #0d1117;
  font-family: 'Barlow Condensed', sans-serif; font-weight: 700;
  font-size: 1rem; letter-spacing: .06em;
  padding: 10px 22px; border-radius: 6px; text-decoration: none;
  transition: background .2s, transform .15s;
  white-space: nowrap;
}
.nav-cta:hover { background: #e08800; transform: translateY(-2px); }

/* Hamburguesa */
.nav-toggle {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.nav-toggle span {
  display: block; width: 24px; height: 2px;
  background: #fff; border-radius: 2px; transition: .3s;
}

/* Menú móvil */
@media (max-width: 860px) {
  .nav-links {
    display: none; flex-direction: column; gap: 0;
    position: fixed; top: 72px; left: 0; right: 0;
    background: rgba(13,17,23,.98);
    border-bottom: 1px solid rgba(255,255,255,.08);
    padding: 16px 0;
  }
  .nav-links.open { display: flex; }
  .nav-links li a {
    display: block; padding: 14px 6%;
    border-bottom: 1px solid rgba(255,255,255,.05);
  }
  .nav-toggle { display: flex; }
}
@media (max-width: 480px) {
  .nav-cta { display: none; }
}
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const links  = document.querySelector('.nav-links');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 40);
  });

  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  // Cerrar menú al hacer clic en un enlace
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
